branch=$(git rev-parse --abbrev-ref HEAD)
pattern='^(feat|fix|chore|refactor|test|ci|docs|build|perf|revert|style)/.+'

if [ "$branch" = "main" ]; then
  echo "Error: direct push to main is not allowed"
  exit 1
fi

if ! echo "$branch" | grep -qE "$pattern"; then
  echo "Error: branch name '$branch' does not follow the convention: <type>/<description>"
  echo "Allowed types: feat, fix, chore, refactor, test, ci, docs, build, perf, revert, style"
  exit 1
fi

pnpm typecheck