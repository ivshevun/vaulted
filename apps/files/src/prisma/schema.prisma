generator client {
  provider = "prisma-client-js"
  output   = "../../../../node_modules/@prisma/files-client"
}

datasource db {
  provider = "postgresql"
  url      = env("FILES_DATABASE_URL")
}

enum FileStatus {
  PENDING
  SCANNING
  CLEAN
  INFECTED
  FAILED
}

model File {
  id String @id @default(uuid())

  key      String @unique()
  slug     String @unique()
  filename String

  contentType String
  size        Int?

  status  FileStatus @default(PENDING)
  scanned Boolean    @default(false)

  userId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
