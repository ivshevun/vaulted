{
  "name": "vaulted",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"e2e/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/vaulted/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest",
    "test:e2e": "dotenv -e .env.test -- jest --config ./e2e/jest-e2e.json --detect-open-handles",
    "test:e2e:watch": "dotenv -e .env.test -- jest --config ./e2e/jest-e2e.json --watchAll",
    "test:e2e:auth:watch": "dotenv -e .env.test -- jest --config ./e2e/jest-e2e.json --watch --testPathPattern=e2e/specs/auth.e2e-spec",
    "test:e2e:files:watch": "dotenv -e .env.test -- jest --config ./e2e/jest-e2e.json --watch --testPathPattern=e2e/specs/files.e2e-spec",
    "typecheck": "tsc --noEmit",
    "docker:test-e2e": "docker compose -f docker-compose.e2e.yaml up -d && docker exec vaulted-api-gateway-test pnpm test:e2e",
    "docker:test-e2e-build": "docker compose -f docker-compose.e2e.yaml up --build -d && docker exec vaulted-api-gateway-test pnpm test:e2e"
  },
  "devDependencies": {
    "@aws-sdk/util-stream": "^3.374.0",
    "@smithy/util-stream": "^4.2.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/passport-local": "^1.0.38",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/amqplib": "^0.10.8",
    "@types/clamscan": "^2.4.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.7",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.1.10",
    "@types/supertest": "^6.0.2",
    "aws-sdk-client-mock": "^4.1.0",
    "aws-sdk-client-mock-jest": "^4.1.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "dotenv": "^16.5.0",
    "dotenv-cli": "^8.0.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-mock-extended": "4.0.0-beta1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.4.2",
    "prisma": "^6.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "uuid": "^11.1.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "pnpm lint",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/libs/",
      "<rootDir>/apps/"
    ],
    "moduleNameMapper": {
      "^@app/common(|/.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/common-tests(|/.*)$": "<rootDir>/libs/common/tests/$1",
      "^@apps/(.*)$": "<rootDir>/apps/$1"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
